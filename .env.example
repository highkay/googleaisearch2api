APP_NAME=Google AI Search2API
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_DATA_DIR=data

DEFAULT_MODEL=google-search
SEARCH_ENGINE=google
API_TOKEN=

BROWSER_HEADLESS=true
BROWSER_USER_AGENT=
BROWSER_LOCALE=en-US
BROWSER_BASE_URL=https://www.google.com/search?udm=50&aep=11&hl=en
BROWSER_TIMEOUT_MS=90000
ANSWER_TIMEOUT_MS=45000
BROWSER_WORKERS=1
REQUEST_QUEUE_SIZE=8
REQUEST_LOG_MAX_ROWS=200
GOOGLE_AI_BLOCKED_RETRY_COUNT=0
DUCK_AI_WORKERS=1
DUCK_AI_QUEUE_SIZE=2
DUCK_AI_COOLDOWN_SECONDS=120
PROXY_ALLOW_FALLBACK_TO_BASE=false

BROWSER_PROXY_SERVER=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=
BROWSER_PROXY_BYPASS=
RESIN_STICKY_SESSION_ENABLED=false

PROXY_AUTO_RECOVERY_ENABLED=false
PROXY_AUTO_RECOVERY_INTERVAL_SECONDS=43200
PROXY_AUTO_RECOVERY_RUN_ON_STARTUP=false
PROXY_AUTO_RECOVERY_EXISTING_SESSIONS=true
PROXY_AUTO_RECOVERY_EXISTING_SESSION_LIMIT=50
PROXY_AUTO_RECOVERY_MAX_PROBES=3
PROXY_AUTO_RECOVERY_TARGET_ACTIVE=1
PROXY_AUTO_RECOVERY_TIMEOUT_SECONDS=300
PROXY_AUTO_RECOVERY_MIN_TRIGGER_INTERVAL_SECONDS=900
PROXY_AUTO_RECOVERY_SKIP_EGRESS=true
PROXY_AUTO_RECOVERY_SKIP_IPLARK=true
PROXY_AUTO_RECOVERY_FAST_IPAPI_EGRESS=false
PROXY_AUTO_RECOVERY_FAST_HTTP_PREFILTER=true
PROXY_AUTO_RECOVERY_FAST_HTTP_TIMEOUT=8
PROXY_AUTO_RECOVERY_FAST_HTTP_SCAN_LIMIT=40
PROXY_AUTO_RECOVERY_ALLOW_KNOWN_GOOGLE_BLOCKED_IP=true
PROXY_AUTO_RECOVERY_ALLOW_KNOWN_GOOGLE_BLOCKED_PREFIX=true
PROXY_AUTO_RECOVERY_RETRY_RETIRED=false
PROXY_AUTO_RECOVERY_SKIP_DUCK_CANARY=true
PROXY_AUTO_RECOVERY_CANARY_REPEATS=1
PROXY_AUTO_RECOVERY_START=1
PROXY_AUTO_RECOVERY_END=1000

# Compose image selection. Prefer sha-* pins for production; latest tracks main.
# GOOGLEAISEARCH2API_IMAGE=ghcr.io/highkay/googleaisearch2api:latest
# GOOGLEAISEARCH2API_PULL_POLICY=always

GOOGLEAISEARCH2API_CPUS=2.0
GOOGLEAISEARCH2API_MEMORY_LIMIT=3g
GOOGLEAISEARCH2API_PIDS_LIMIT=512
